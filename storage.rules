rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Ảnh giải (banner/logo/sponsor): đọc public; ghi nếu đã đăng nhập + ảnh < 5MB.
    // (Việc gắn URL vào doc giải vẫn do CF kiểm tra owner/admin — upload đơn lẻ không đổi được giải nào.)
    match /tournaments/{tid}/{file=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} { allow read, write: if false; }
  }
}
